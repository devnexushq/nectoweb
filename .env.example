# Frontend-safe Supabase configuration.
# These values are public browser configuration, not service/admin secrets.
VITE_SUPABASE_URL="https://your-project-ref.supabase.co"
VITE_SUPABASE_PUBLISHABLE_KEY="your-supabase-publishable-or-anon-key"
VITE_SUPABASE_PROJECT_ID="your-project-ref"

# Backend-only secrets must stay in Supabase/Vercel dashboards, never in frontend code:
# SUPABASE_SERVICE_ROLE_KEY
# SUPABASE_JWT_SECRET
# Database password / connection string
